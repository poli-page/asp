# Normalize line endings to LF on checkout for every platform.
# The .editorconfig enforces `end_of_line = lf`, and `dotnet format --verify-no-changes`
# fails (ENDOFLINE) when Windows runners check files out with CRLF via core.autocrlf.
# Forcing eol=lf keeps the Format check green on windows-latest too.
* text=auto eol=lf

# Explicitly treat known text types as LF.
*.cs    text eol=lf
*.csproj text eol=lf
*.sln   text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.editorconfig text eol=lf

# Binary types — never normalize.
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.snk   binary
*.nupkg binary
